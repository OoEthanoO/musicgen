# OPTIONAL. With no token the app runs on the built-in local synth (no key needed).
# Add a token to switch /api/generate to real MusicGen continuation.
# Get one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

